rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: vocabulary_topics
    // Fields: id, title, level, wordCount, image, description
    //
    // Collection: grammar_topics
    // Fields: id, title, level, description, isPro, count
    //
    // Collection: grammar_lessons
    // Fields: topicId, title, intro, example, sections
    //
    // Collection: grammar_questions
    // Fields: topicId, word, options, correct
    //
    // Collection: users
    // Fields: uid, email, role, displayName
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "phamhathang393@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Validation Helpers
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    // Rules for collections
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && 
        hasOnlyAllowedFields(['uid', 'email', 'role', 'displayName']) &&
        (request.resource.data.role == 'user' || isAdmin());
    }

    match /vocabulary_topics/{topicId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /vocabulary_words/{wordId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /grammar_topics/{topicId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /grammar_lessons/{lessonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /grammar_questions/{questionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /user_vocabulary_progress/{progressId} {
      function isValidProgress(data) {
        return data.userId is string && data.userId == request.auth.uid &&
               data.wordId is string &&
               data.topicId is string &&
               data.rating in ['again', 'hard', 'good', 'easy'] &&
               (data.repetitionCount is number || data.repetitionCount == null) &&
               (data.lastStudiedAt is timestamp || data.lastStudiedAt == null) &&
               (data.nextReviewAt is timestamp || data.nextReviewAt == null) &&
               (data.updatedAt is timestamp || data.updatedAt == null);
      }

      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidProgress(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidProgress(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
